#!/usr/bin/env bash


usage() {
    local b; b="$(printf '\e[1m')"
    local u; u="$(printf '\e[4m')"
    local i; i="$(printf '\e[3m')"
    local r; r="$(printf '\e[0m')"

    cat <<EOF

${b}NAME${r}
       ${u}git-context-graph${r} - Show graph log of branch, default branch, and their remote counterparts.

${b}SYNOPSIS${r}
       ${u}git${r} ${u}context-graph${r} [--local] [--no-default] [-a|--add] [<base_branch>...]
       ${u}git${r} ${u}context-graph${r} [<git-log options>...] [<options>...] [<base_branch>...] [-- <paths>...]

       ${u}git${r} ${u}context-graph${r} (-l|--list) [-s|--short] [<base_branch>...]
       ${u}git${r} ${u}context-graph${r} [<base_branch>] (-v|--list-status)

       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-A|--config-add) <additional_branch>... [-S|--sync]
       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-C|--config-clear) [<additional_branch>...] [-S|--sync]
       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-T|--config-toggle) <additional_branch>... [-S|--sync]
       ${u}git${r} ${u}context-graph${r} [<base_branch>]    (-S|--sync)
       ${u}git${r} ${u}context-graph${r} (-Z|--config-reset)

       ${u}git${r} ${u}context-graph${r} (-h|--usage)

${b}DESCRIPTION${r}
   ${b}Principle${r}
       This command is a shortcut to:

           ${i}git log --color --graph --abbrev-commit --decorate --pretty=oneline \\
               my-branch origin/my-branch \\
               main      origin/main ...${r}

       By default, a branch is shown along with the default branch ('main' / 'master'),
       their remote counterparts, and its configured additional context branches.

   ${b}Usage${r}
       ${u}git${r} ${u}context-graph${r} [--local] [--no-default] [-a|--add] [<base_branch>...]
           Show the context graph.

       ${u}git${r} ${u}context-graph${r} [<git-log options>...] [<options>...] [<base_branch>...] [-- <paths>...]
           Pass any git-log option through to refine the output (see https://git-scm.com/docs/git-log).
           Ex: git context-graph --pretty=medium -- some/path

       ${u}git${r} ${u}context-graph${r} (-l|--list) [-s|--short] [<base_branch>...]
           List the branches that would be shown, instead of drawing the graph.

       ${u}git${r} ${u}context-graph${r} [<base_branch>] (-v|--list-status)
           List local branches, flagging those in the current branch's context.
           ' * ' current / reference, '[*]' in context, '[ ]' not in context.

   ${b}Branch context configuration${r}
       Context branches are persisted per branch (in branch.<name>.context) and
       automatically included whenever you graph it.

       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-A|--config-add) <additional_branch>...
       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-C|--config-clear) [<additional_branch>...]
       ${u}git${r} ${u}context-graph${r} [<base_branch>...] (-T|--config-toggle) <additional_branch>...
           Add, clear, or toggle a branch's context (see OPTIONS).

       ${u}git${r} ${u}context-graph${r} [<base_branch>] [<config edit>] (-S|--sync)
           Synchronize a branch's context so that every member references all the others,
           or propagate a config edit to the whole preset (see OPTIONS).

       ${u}git${r} ${u}context-graph${r} (-Z|--config-reset)
           Remove all branch context configuration from the repository (see OPTIONS).

${b}ARGUMENTS${r}
       <base_branch>...
           Branch(es) to show graph for. If omitted, current branch will be used.

${b}OPTIONS${r}
   ${b}Graphing${r}
       -a|--add <additional_branch>...
           Consider <additional_branch> argument(s) as additional branches (added to current branch).

       --local
           Show only local branches (ignore remotes).

       --no-default
           Show only related branches (local and remote), without default branch ('main' / 'master').

   ${b}Listing${r}
       -l|--list
           List branches that would be shown in the graph (does not display graph).

       -s|--short
           Use short branch names when listing branches (without 'refs/heads/' or 'refs/remotes/').
           Implies --list.

       -v|--list-status
           List local branches, flagging those in the current branch's context.
           ' * ' current / reference, '[*]' in context, '[ ]' not in context.

   ${b}Branch context configuration${r}
       -A|--config-add <additional_branch>...
           Persist additional context branches for a branch.

       -C|--config-clear [<additional_branch>...]
           Remove context branches for a branch (all of them, if none specified).

       -T|--config-toggle <additional_branch>...
           Toggle context branches for a branch.

       -S|--sync
           Synchronize a branch's context into a shared preset where every branch in the set
           references all the others. Works on its own or propagates an edit to the whole preset
           (--config-add/--config-clear/--config-toggle).
           A branch removed from the preset is detached from all its members,
           keeping only unrelated context.

       -Z|--config-reset
           Remove all branch context configuration from the repository, after confirmation.

   ${b}Help${r}
       -h|--usage
           Show this help.
EOF
}

################################################################################
# Git utility functions

git_current_branch() {
    # `git branch --show-current` is available starting from Git 2.22
    # fallback to `git rev-parse --abbrev-ref HEAD` if first command fails
    (git branch --show-current 2>/dev/null) ||
        git rev-parse --abbrev-ref HEAD
}

branch_with_remotes() {
    local branch=${1:-$(git_current_branch)}

    # Convert 'refs/heads/my-branch' to 'my-branch'
    local short_branch=${branch#"refs/heads/"}

    if [[ $short_branch == "HEAD" ]]; then
        echo "$branch"
        return
    fi

    local ref_patterns=("refs/heads/$short_branch")
    if [[ -z $GIT_CG_SHOW_LOCAL_ONLY ]]; then
        local remote
        for remote in $(git remote); do
            ref_patterns+=("refs/remotes/${remote}/${short_branch}")
        done
    fi

    # Branches with same name on all remotes
    local same_name_refs;
    same_name_refs=$(git for-each-ref --format="%(refname)" "${ref_patterns[@]}")
    echo "$same_name_refs"

    [[ -n $GIT_CG_SHOW_LOCAL_ONLY ]] && return

    # Remote tracking branch (in case name is different)
    local tracking_remote;
    tracking_remote=$(git for-each-ref --format='%(upstream)' "$(git rev-parse --symbolic-full-name "$branch" 2> /dev/null)")
    [[ ! $same_name_refs =~ $tracking_remote ]] && echo "$tracking_remote"
}

################################################################################
# Branch listing functions

related_branches() {
    local branches=("$@")

    local current_branch;
    current_branch=$(git_current_branch)
    [[ -z $current_branch ]] && current_branch="HEAD"

    # Default to current branch
    [[ ${#branches[@]} -eq 0 ]] && branches[0]="$current_branch"

    # Add current branch to list when considering arguments are additional branches
    [[ -n $GIT_CG_ADD_TO_CURRENT ]] && branches+=("$current_branch")

    local branch
    local related_branches
    for branch in "${branches[@]}"; do
        related_branches="${related_branches}\n$(branch_with_remotes "$branch")"
    done

    # de-duplicate and remove blank lines
    echo -e "${related_branches}" | sort -u | grep "\S"
}

additional_branches() {
    local branch="$1"
    local short_branch=${branch#"refs/heads/"}

    git config --local --get-all "branch.${short_branch}.context"
}

default_branches() {
    local default_branches

    # default remote branches
    local remote
    for remote in $(git remote); do
        local remote_default
        remote_default=$(git symbolic-ref "refs/remotes/${remote}/HEAD" -- 2>/dev/null)

        if [[ -n $remote_default ]]; then
            local short_remote_default=${remote_default#"refs/remotes/"}

            local short_tracking_default
            short_tracking_default=$(git branch -vv | grep "$short_remote_default" | sed 's/^[* ]*//' | cut -d' ' -f1)

            local short_default
            [[ -n $short_tracking_default ]] &&
                short_default="$short_tracking_default" ||
                short_default=${remote_default#"refs/remotes/${remote}/"}

            default_branches="${default_branches}\n${short_default}"
        fi
    done

    # standard default branches
    if [[ -z $default_branches ]]; then
        local std_default
        for std_default in 'main' 'master'; do
            git show-ref --verify --quiet "refs/heads/$std_default" &&
                default_branches="${default_branches}\n${std_default}"
        done
    fi

    # de-duplicate and remove blank lines
    echo -e "${default_branches}" | sort -u | grep "\S"
}

context_branches() {
    local context_branches
    context_branches="$(related_branches "$@")"

    local context_branch
    for context_branch in $(echo "$context_branches" | grep "^refs/heads/" ); do
        local additional_branch
        for additional_branch in $(additional_branches "$context_branch"); do
            context_branches="${context_branches}\n$(branch_with_remotes "$additional_branch")"
        done
    done

    if [[ -z $GIT_CG_SHOW_RELATED_ONLY ]]; then
        local default_branch
        for default_branch in $(default_branches); do
            context_branches="${context_branches}\n$(branch_with_remotes "$default_branch")"
        done
    fi

    # de-duplicate and remove blank lines
    context_branches=$(echo -e "${context_branches}" | sort -u | grep "\S")

    # short branch listing
    [[ -n $GIT_CG_LIST_SHORT ]] && context_branches=$(echo "$context_branches" |
        sed -e "s/^refs\/heads\///" |
        sed -e "s/^refs\/remotes\///")

    echo "$context_branches"
}

list_branch_context_status() {
    local ref_branch=${1:-$(git_current_branch)}

    # Default branch(es) are excluded from the listing
    local defaults
    defaults=$(default_branches)

    # Reference branch's context, local + short names (reuses existing logic).
    # Pass ref_branch only when set (empty on a detached HEAD)
    local context
    context=$(\
        GIT_CG_SHOW_LOCAL_ONLY=1 \
        GIT_CG_SHOW_RELATED_ONLY=1 \
        GIT_CG_LIST_SHORT=1 \
        context_branches ${ref_branch:+"$ref_branch"})

    # Reference branch is listed inline (alphabetical) rather than pinned first,
    # so the ordering stays stable across invocations.

    local branch status
    while IFS= read -r branch; do
        grep -qxF "$branch" <<< "$defaults" && continue

        if [[ $branch == "$ref_branch" ]]; then
            status=' * '
        elif grep -qxF "$branch" <<< "$context"; then
            status='[*]'
        else
            status='[ ]'
        fi
        printf '%s\t%s\n' "$status" "$branch"
    done < <(git for-each-ref --format='%(refname:short)' refs/heads/)
}

################################################################################
# Additional branch configuration functions

resolve_source_branch() {
    # Echo the branch to configure (given argument or current branch),
    # failing on a detached HEAD.
    local branch=${1:-$(git_current_branch)}
    branch=${branch#"refs/heads/"}
    if [[ -z $branch || $branch == "HEAD" ]]; then
        echo "Unable to configure additional branch to detached HEAD." >&2
        echo "Please checkout a branch or add source branch argument." >&2
        return 1
    fi
    echo "$branch"
}

apply_context_edit() {
    # Apply the requested add/clear/toggle edit to a single branch's context.
    local branch=$1

    if [[ $GIT_CG_CONFIG_CLEAR -eq 1 ]]; then
        clear_additional_branches "$branch" "${GIT_CG_CLEAR_BRANCHES[@]}"
    fi
    if [[ $GIT_CG_CONFIG_ADD -eq 1 ]]; then
        add_additional_branches "$branch" "${GIT_CG_ADD_BRANCHES[@]}"
    fi
    if [[ $GIT_CG_CONFIG_TOGGLE -eq 1 ]]; then
        toggle_additional_branches "$branch" "${GIT_CG_TOGGLE_BRANCHES[@]}"
    fi
}

configure_additional_branches() {
    # Default to current branch, fail if unable
    if [[ ${#GIT_CG_BRANCHES[@]} -eq 0 ]]; then
        GIT_CG_BRANCHES[0]=$(resolve_source_branch) || exit 1
    fi

    local branch
    for branch in "${GIT_CG_BRANCHES[@]}"; do

        apply_context_edit "$branch"

        local additional_branches
        additional_branches=$(additional_branches "$branch")
        if [[ -n $additional_branches ]]; then
            echo "Additional context branches for $branch:"
            # shellcheck disable=SC2001 # We need to replace all lines
            echo "$additional_branches" | sed 's/^/  /'
        else
            [[ $GIT_CG_CONFIG_CLEAR -eq 1 ]] &&
                echo "Cleared additional context branches for $branch." ||
                echo "No additional context branches for $branch."
        fi
    done
}

add_additional_branches() {
    local source_branch=$1
    local additional_branches=("${@:2}")

    if [[ -z $source_branch ]]; then
        echo "No branch to configure." >&2
        exit 1
    fi
    if [[ ${#additional_branches[@]} -eq 0 ]]; then
        echo "No additional context branch." >&2
        exit 1
    fi

    local branch
    for branch in "${additional_branches[@]}"; do
        local add=${branch#"refs/heads/"}

        [[ $source_branch = "$add" ]] &&
            continue # same branch

        [[ -z $(git for-each-ref --format="%(refname)" "refs/**/$add") ]] &&
            continue # unknown branch

        additional_branches "$source_branch" | grep -qxF "$add" ||
            git config --local --add -- "branch.${source_branch}.context" "$add"
    done
}

clear_additional_branches() {
    local source_branch=$1
    local additional_branches=("${@:2}")

    if [[ -z $source_branch ]]; then
        echo "No branch to configure." >&2
        exit 1
    fi

    if [[ ${#additional_branches[@]} -eq 0 ]]; then
        git config --local --unset-all "branch.${source_branch}.context"
    else
        local branch
        for branch in "${additional_branches[@]}"; do
            git config --local --unset --fixed-value "branch.${source_branch}.context" "$branch"
        done
    fi
}

toggle_additional_branches() {
    local source_branch=$1
    local additional_branches=("${@:2}")

    if [[ -z $source_branch ]]; then
        echo "No branch to configure." >&2
        exit 1
    fi
    if [[ ${#additional_branches[@]} -eq 0 ]]; then
        echo "No additional context branch." >&2
        exit 1
    fi

    local branch
    for branch in "${additional_branches[@]}"; do
        local toggle=${branch#"refs/heads/"}

        if additional_branches "$source_branch" | grep -qxF "$toggle"; then
            clear_additional_branches "$source_branch" "$toggle" # already configured
        else
            add_additional_branches "$source_branch" "$toggle"   # not configured yet
        fi
    done
}

preset_members() {
    # Source branch + its directly configured context (short local names)
    local source=$1
    { echo "$source"; additional_branches "$source"; } | sort -u | grep "\S"
}

configure_and_sync() {
    # --sync builds a "preset": after editing one branch's context, mirror the
    # resulting set to every member, and detach any branch the edit dropped
    # (stripping only the preset members, so unrelated context is preserved).

    # The preset is defined by a single source branch
    if [[ ${#GIT_CG_BRANCHES[@]} -gt 1 ]]; then
        echo "--sync operates on a single branch's context." >&2
        exit 1
    fi

    local source
    source=$(resolve_source_branch "${GIT_CG_BRANCHES[0]}") || exit 1

    # Preset membership before the edit
    local before
    before=$(preset_members "$source")

    # Apply the requested edit to the source branch only
    apply_context_edit "$source"

    # Preset membership after the edit
    local after
    after=$(preset_members "$source")

    local after_members=()
    local member
    while IFS= read -r member; do
        [[ -n $member ]] && after_members+=("$member")
    done <<< "$after"

    # Branches dropped from the preset by the edit
    local removed=()
    while IFS= read -r member; do
        [[ -z $member ]] && continue
        grep -qxF "$member" <<< "$after" || removed+=("$member")
    done <<< "$before"

    # Mirror the resulting set: every member references all the others (replace
    # existing context). add_additional_branches skips the source itself.
    if [[ ${#after_members[@]} -ge 2 ]]; then
        for member in "${after_members[@]}"; do
            clear_additional_branches "$member"
            add_additional_branches "$member" "${after_members[@]}"
        done
    fi

    # Detach dropped branches from the whole preset (retained and dropped members
    # alike), so leaving the preset conserves only their unrelated context.
    local dropped
    for dropped in "${removed[@]}"; do
        clear_additional_branches "$dropped" "${after_members[@]}" "${removed[@]}"
    done

    # Report
    if [[ ${#after_members[@]} -ge 2 ]]; then
        echo "Synchronized context for branches:"
        printf '  %s\n' "${after_members[@]}"
    elif [[ ${#removed[@]} -gt 0 ]]; then
        echo "Context preset for $source is now empty."
    else
        echo "Nothing to synchronize: less than two branches in context." >&2
        exit 1
    fi
    if [[ ${#removed[@]} -gt 0 ]]; then
        echo "Detached from preset:"
        printf '  %s\n' "${removed[@]}"
    fi
}

reset_context_config() {
    # All branches with configured context (keys look like 'branch.<name>.context')
    local keys
    keys=$(git config --local --name-only --get-regexp '^branch\..*\.context$' 2>/dev/null | sort -u)

    if [[ -z $keys ]]; then
        echo "No branch context configuration to reset."
        return
    fi

    echo "This will remove context configuration for the following branches:"
    local key
    while IFS= read -r key; do
        local branch=${key#"branch."}
        branch=${branch%".context"}
        echo "  $branch"
    done <<< "$keys"

    local reply
    read -r -p "Proceed? [y/N] " reply
    if [[ ! $reply =~ ^[Yy]$ ]]; then
        echo "Aborted."
        return
    fi

    while IFS= read -r key; do
        git config --local --unset-all "$key"
    done <<< "$keys"

    echo "Branch context configuration removed."
}

################################################################################
# Main

# Check current directory is a Git repository
if ! git rev-parse 2> /dev/null; then
    echo "Not a git repository"
    exit 1
fi

# Parse options & arguments
GIT_CG_BRANCHES=()
GIT_CG_ADD_BRANCHES=()
GIT_CG_CLEAR_BRANCHES=()
GIT_CG_TOGGLE_BRANCHES=()
GIT_LOG_OPTIONS=()
GIT_LOG_PATHS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--add) GIT_CG_ADD_TO_CURRENT=1; shift ;;

        --local)      GIT_CG_SHOW_LOCAL_ONLY=1;   shift ;;
        --no-default) GIT_CG_SHOW_RELATED_ONLY=1; shift ;;

        -l|--list)  GIT_CG_LIST=1;                      shift ;;
        -s|--short) GIT_CG_LIST=1; GIT_CG_LIST_SHORT=1; shift ;;

        -v|--list-status) GIT_CG_LIST_STATUS=1; shift ;;

        -A|--config-add)    GIT_CG_CONFIGURE="add";    GIT_CG_CONFIG_ADD=1;    shift ;;
        -C|--config-clear)  GIT_CG_CONFIGURE="clear";  GIT_CG_CONFIG_CLEAR=1;  shift ;;
        -T|--config-toggle) GIT_CG_CONFIGURE="toggle"; GIT_CG_CONFIG_TOGGLE=1; shift ;;
        -Z|--config-reset)  GIT_CG_CONFIGURE="reset";  shift ;;
        -S|--sync)          GIT_CG_CONFIG_SYNC=1;      shift ;;

        -h|--usage) GIT_CONTEXT_GRAPH_HELP=1; shift ;;

        --) GIT_LOG_PATHS+=("$1");   shift ;;
        -*) GIT_LOG_OPTIONS+=("$1"); shift ;;
         *)
            if   [[ ${#GIT_LOG_PATHS[@]} -gt 0 ]];    then GIT_LOG_PATHS+=("$1")          # git-log path argument (after '--')
            elif [[ $GIT_CG_CONFIGURE == "add" ]];    then GIT_CG_ADD_BRANCHES+=("$1")    # additional branch to add to config
            elif [[ $GIT_CG_CONFIGURE == "clear" ]];  then GIT_CG_CLEAR_BRANCHES+=("$1")  # additional branch to remove from config
            elif [[ $GIT_CG_CONFIGURE == "toggle" ]]; then GIT_CG_TOGGLE_BRANCHES+=("$1") # additional branch to toggle in config
            else                                           GIT_CG_BRANCHES+=("$1")        # git-context-graph branch argument
            fi; shift ;;
    esac
done


# Context branch configuration
if [[ -n $GIT_CG_CONFIGURE || -n $GIT_CG_CONFIG_SYNC ]]; then
    if [[ $GIT_CG_CONFIGURE == "reset" ]]; then
        reset_context_config
    elif [[ -n $GIT_CG_CONFIG_SYNC ]]; then
        # --sync works both standalone and after an add/clear/toggle edit
        configure_and_sync
    else
        configure_additional_branches
    fi
    exit 0
fi

# Alternative outputs
if [[ -n $GIT_CG_LIST_STATUS ]]; then
    list_branch_context_status "${GIT_CG_BRANCHES[@]}"
    exit $?
fi
if [[ -n $GIT_CG_LIST ]]; then
    context_branches "${GIT_CG_BRANCHES[@]}"
    exit 0
fi
if [[ -n $GIT_CONTEXT_GRAPH_HELP ]]; then
    usage
    exit 0
fi


# Show graph
# shellcheck disable=SC2046 # use word splitting for GIT_CG_BRANCHES
git \
    -c log.excludeDecoration='refs/remotes/*/HEAD' \
    log --color --graph --abbrev-commit --decorate --pretty=oneline \
    "${GIT_LOG_OPTIONS[@]}" \
    $(context_branches "${GIT_CG_BRANCHES[@]}") \
    "${GIT_LOG_PATHS[@]}"
